// Prisma schema for the Real-Time Chat Platform.
// IMPLEMENTED & WIRED UP THIS PASS: User, FriendRequest, Friend, Conversation,
//   ConversationMember, Message, RefreshToken.
// MODELED BUT NOT YET WIRED UP (schema exists, no controller logic): Attachment,
//   Reaction, Notification, Report. These are here so future work doesn't require
//   a migration, but nothing in src/ reads or writes them yet. See README "What's
//   stubbed" section.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String  @id @default(uuid())
  name          String
  username      String  @unique
  email         String  @unique
  password      String
  avatar        String?
  bio           String?
  statusMessage String?
  role          String  @default("USER")
  accountStatus String  @default("ACTIVE")

  isOnline   Boolean  @default(false)
  lastSeenAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sentFriendRequests     FriendRequest[] @relation("SentRequests")
  receivedFriendRequests FriendRequest[] @relation("ReceivedRequests")

  friendsInitiated Friend[] @relation("FriendUser")
  friendsReceived  Friend[] @relation("FriendOf")

  conversationMemberships ConversationMember[]
  messages                Message[]
  reactions               Reaction[]
  notifications           Notification[]
  refreshTokens           RefreshToken[]

  @@map("users")
}

// A row is created in PENDING state; on accept we also write two Friend rows
// (one per direction) so friendship lookups don't need an OR query both ways.
model FriendRequest {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sender   User @relation("SentRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@map("friend_requests")
}

model Friend {
  id       String @id @default(uuid())
  userId   String
  friendId String

  user   User @relation("FriendUser", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendOf", fields: [friendId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, friendId])
  @@map("friends")
}

model Conversation {
  id          String   @id @default(uuid())
  type        String
  name        String? // group name; null for DIRECT
  avatar      String? // group icon; null for DIRECT
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members  ConversationMember[]
  messages Message[]

  @@map("conversations")
}

model ConversationMember {
  id             String   @id @default(uuid())
  conversationId String
  userId         String
  role           String   @default("MEMBER")
  joinedAt       DateTime @default(now())
  lastReadAt     DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("conversation_members")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  type           String   @default("TEXT")
  replyToId      String?
  isEdited       Boolean  @default(false)
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  replyTo      Message?     @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies      Message[]    @relation("MessageReplies")

  attachments Attachment[]
  reactions   Reaction[]

  @@index([conversationId, createdAt])
  @@map("messages")
}

// STUB — not yet read/written by any controller. Upload route in
// routes/upload.routes.ts returns 501 Not Implemented.
model Attachment {
  id        String   @id @default(uuid())
  messageId String
  fileUrl   String
  fileType  String
  fileSize  Int
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("attachments")
}

// STUB — not yet read/written by any controller.
model Reaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@map("reactions")
}

// STUB — not yet read/written by any controller.
model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  payload   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// STUB — not yet read/written by any controller. Admin routes return 501.
model Report {
  id         String   @id @default(uuid())
  reporterId String
  targetType String // "message" | "user" | "group"
  targetId   String
  reason     String
  createdAt  DateTime @default(now())

  @@map("reports")
}

// Refresh tokens are stored hashed so login sessions survive server restarts
// and can be revoked individually (e.g. on logout or password reset).
model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}
