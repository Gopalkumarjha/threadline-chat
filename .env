# Postgres connection string. The docker-compose.yml in the repo root spins up
# a local Postgres matching these defaults.
DATABASE_URL="postgresql://chatapp:chatapp@localhost:5432/chatapp?schema=public"

# Used to sign short-lived access tokens (sent in the Authorization header).
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"

# Used to sign longer-lived refresh tokens (stored as an httpOnly cookie).
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_REFRESH_EXPIRES_IN="7d"

PORT=4000
NODE_ENV=development

# Comma-separated list of origins allowed to call the API / connect via socket.
CORS_ORIGIN="http://localhost:5173"
